<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!--
      HttpPlatformHandler launches uvicorn as a child process.
      IIS listens on port 80/443 and forwards traffic to %HTTP_PLATFORM_PORT%.
      Adjust pythonPath below to match the deployed Python location.
    -->
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform processPath="%PYTHON_HOME%\python.exe"
                  arguments="-m uvicorn app.main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT%"
                  startupTimeLimit="60"
                  startupRetryCount="3"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout">
      <environmentVariables>
        <environmentVariable name="PYTHONPATH" value="." />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
