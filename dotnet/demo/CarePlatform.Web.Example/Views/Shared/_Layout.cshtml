@using CarePlatform.Web.Example.Controllers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VistA Example</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cp-chrome.css" asp-append-version="true" />
</head>
<body>
    @if (ViewData["HideChrome"] as bool? != true)
    {
        <header>
            <nav class="navbar navbar-expand navbar-dark cp-menubar py-0" aria-label="Main menu">
                <div class="container-fluid">
                    <a class="navbar-brand mb-0 h6" href="/"><i class="bi bi-hdd-network"></i> VistA Example</a>
                    <ul class="navbar-nav me-auto">
                        @* ── File ── *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle py-1" href="#" data-bs-toggle="dropdown" role="button" aria-expanded="false">File</a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" href="#" onclick="event.preventDefault();location.reload();"><i class="bi bi-arrow-clockwise me-2"></i>Refresh</a></li>
                                @if (!string.IsNullOrEmpty(Context.Session.GetString("UserName")))
                                {
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form method="post" asp-controller="Home" asp-action="Disconnect" class="m-0">
                                            <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right me-2"></i>Sign Out</button>
                                        </form>
                                    </li>
                                }
                                else
                                {
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" href="/"><i class="bi bi-box-arrow-in-right me-2"></i>Sign In</a></li>
                                }
                            </ul>
                        </li>

                        @* ── Help ── *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle py-1" href="#" data-bs-toggle="dropdown" role="button" aria-expanded="false">Help</a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#aboutModal"><i class="bi bi-info-circle me-2"></i>About</a></li>
                            </ul>
                        </li>
                    </ul>
                    @if (!string.IsNullOrEmpty(Context.Session.GetString("UserName")))
                    {
                        <div class="d-flex align-items-center text-light small">
                            <span class="me-3">Signed in as <strong>@Context.Session.GetString("UserName")</strong></span>
                        </div>
                    }
                </div>
            </nav>
        </header>
    }

    <main role="main" class="cp-main">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    @if (ViewData["HideChrome"] as bool? != true)
    {
        <footer class="cp-statusbar" role="contentinfo" aria-label="Application status">
            <div class="container-fluid d-flex justify-content-between">
                <span>@(Context.Session.GetString("SiteId") is string sid ? $"Site {sid}" : "")</span>
                <span></span>
                <span>VistA Example v1.0</span>
            </div>
        </footer>

        @* About modal *@
        <div class="modal fade" id="aboutModal" tabindex="-1" aria-labelledby="aboutModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="aboutModalLabel">About</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <h6>VistA Example Frontend</h6>
                        <p class="mb-1">Version 1.0 (Web)</p>
                        <p class="mb-1 text-muted small">Connects directly to Mock VistA via the XWB broker protocol (TCP).</p>
                        <p class="mb-0 text-muted small">CarePlatform CORE &mdash; Care Platform legacy-tool migration.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
