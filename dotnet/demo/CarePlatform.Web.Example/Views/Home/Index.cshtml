@{
    ViewData["Title"] = "Sign In";
    ViewData["HideChrome"] = true;
}

<div class="cp-login-container" style="max-width: 480px;">
    <div class="cp-login-card">
        <div class="cp-login-header">
            <i class="bi bi-hdd-network" style="font-size:2rem;"></i>
            <h4>VistA Example</h4>
            <p class="login-subtitle">Care Platform CORE</p>
        </div>
        <div class="cp-login-body">
            @if (ViewData["Error"] is string error && !string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger py-2" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @error
                </div>
            }

            <h5 class="text-center mb-4">Please choose your method for signing in:</h5>

            <div class="d-grid gap-3">
                <a asp-action="PivLogin" class="btn btn-primary btn-lg d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-shield-lock" style="font-size:1.4rem;"></i>
                    <span>Sign In with PIV / Smart Card</span>
                </a>

                <a asp-action="Login" class="btn btn-outline-secondary btn-lg d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-key" style="font-size:1.4rem;"></i>
                    <span>Sign In with Access Code / Verify Code</span>
                </a>
            </div>

            <div class="text-center mt-4">
                <small class="text-muted">Department of Veterans Affairs</small>
            </div>
        </div>
    </div>
</div>
