@{
    ViewBag.Title = "Error";
}

<h1 class="text-danger">Error.</h1>
<h2 class="text-danger">An error occurred while processing your request.</h2>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">
        <strong>Details:</strong> @ViewBag.ErrorMessage
    </div>
}
