@{
    ViewData["Title"] = "Dashboard";
    var user = ViewBag.UserInfo as CarePlatform.Web.Example.Controllers.HomeController.UserInfo;
}

<div class="row justify-content-center">
    <div class="col-md-8">

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <div class="card shadow mb-4">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Connected to VistA</h5>
                <form method="post" asp-action="Disconnect" class="mb-0">
                    <button type="submit" class="btn btn-sm btn-outline-light">Disconnect</button>
                </form>
            </div>
            <div class="card-body">
                @if (user != null)
                {
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr><th style="width:180px">Name</th><td>@user.Name</td></tr>
                            <tr><th>DUZ</th><td>@user.Duz</td></tr>
                            <tr><th>Title</th><td>@(user.Title ?? "—")</td></tr>
                            <tr><th>Service / Section</th><td>@(user.ServiceSection ?? "—")</td></tr>
                            <tr><th>Division</th><td>@(user.Division ?? "—")</td></tr>
                            <tr><th>Language</th><td>@(user.Language ?? "—")</td></tr>
                            <tr><th>DTIME</th><td>@(user.Dtime ?? "—")</td></tr>
                            <tr><th>Site ID</th><td>@ViewBag.SiteId</td></tr>
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">User info not available.</p>
                }
            </div>
        </div>

        <div class="card shadow mb-4">
            <div class="card-header">
                <h6 class="mb-0">Session Details</h6>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr>
                            <th style="width:180px">Session Status</th>
                            <td>@ViewBag.SessionStatus</td>
                        </tr>
                        <tr>
                            <th>JWT Token</th>
                            <td>
                                <code style="word-break:break-all; font-size:0.75rem;">
                                    @ViewBag.Token
                                </code>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-header">
                <h6 class="mb-0">What's Next?</h6>
            </div>
            <div class="card-body">
                <p>You're authenticated. Use the JWT above as a <code>Bearer</code> token to call any API endpoint:</p>
                <pre class="bg-light p-3 rounded"><code>curl -H "Authorization: Bearer &lt;token&gt;" https://localhost:5001/api/user/info
curl -H "Authorization: Bearer &lt;token&gt;" https://localhost:5001/api/patient/select?dfn=3
curl -H "Authorization: Bearer &lt;token&gt;" https://localhost:5001/api/note/list?dfn=3&amp;context=1</code></pre>
                <p class="mb-0 text-muted small">
                    See the <a href="https://github.com/EngiCare/care-platform-data-vista">README</a> for the full endpoint reference.
                </p>
            </div>
        </div>

    </div>
</div>
